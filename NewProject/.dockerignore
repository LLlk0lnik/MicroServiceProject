# Git
.git/
.gitignore
.gitattributes

# Environment files (не нужны в образе, передаются через docker-compose)
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environments (не нужны в контейнере)
venv/
ENV/
env/
.venv

# Poetry lock (пересоздается в контейнере)
poetry.lock

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Tests
tests/
.pytest_cache/
.coverage
htmlcov/
.tox/

# Documentation
*.md
!README.md
docs/

# CI/CD
.github/
.gitlab-ci.yml
Jenkinsfile

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Logs (не нужны в образе)
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Database files (БД в отдельном контейнере)
*.db
*.sqlite
*.sqlite3

# Alembic (migrations нужны, но не __pycache__)
**/__pycache__

# Temporary files
*.tmp
*.bak
*.swp
